{
  "expo": {
    "name": "Davenport",
    "slug": "davenport-wardrobe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "davenport",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0E8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.davenportwardrobe.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Camera access is used to scan payment card details for faster checkout.",
        "NSPhotoLibraryUsageDescription": "Photo library access is not used by this app.",
        "NSMicrophoneUsageDescription": "Microphone access is not used by this app."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1B2A4A"
      },
      "package": "com.davenportwardrobe.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.davenportwardrobe",
          "enableGooglePay": true
        }
      ],
      "expo-image"
    ],
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "69329409-f8f2-4601-ab4f-d9b4cc0d71a9"
      }
    }
  }
}
